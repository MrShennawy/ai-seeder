{
    "name": "mrshennawy/ai-seeder",
    "description": "Generate smart, context-aware dummy data for Laravel databases using the Laravel 12 AI SDK.",
    "keywords": ["laravel", "seeder", "ai", "database", "faker", "dummy-data"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Mahmoud Shennawy",
            "email": "m.alshenaawy@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/support": "^12.0",
        "laravel/ai": "^0.2",
        "laravel/prompts": "^0.3|^0.4|^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Shennawy\\AiSeeder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Shennawy\\AiSeeder\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Shennawy\\AiSeeder\\AiSeederServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
